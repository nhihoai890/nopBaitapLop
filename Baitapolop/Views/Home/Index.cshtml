@{
    ViewData["Title"] = "Home Page";
}

@model List<Baitapolop.Models.Course>
<h2>Khóa học</h2>
<a href="/Course/Create">+ Thêm</a>
<table border="1" cellpadding="8">
    <tr><th>Tên</th><th></th></tr>
    @foreach (var c in Model)
    {
        <tr>
            <td>@c.Name</td>
            <td><a href="/Course/Edit/@c.Id">Sửa</a> | <a href="/Course/Delete/@c.Id">Xóa</a></td>
        </tr>
    }
</table>
